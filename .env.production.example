# Production environment template
# Copy to .env.production and set your deployment URLs
REACT_APP_API_URL=https://your-sonarft-api-domain.com
REACT_APP_WS_URL=wss://your-sonarft-api-domain.com/ws

# After setting the above, also update the connect-src directive in public/index.html
# to replace http://localhost:5000 and ws://localhost:5000 with your production URLs.
